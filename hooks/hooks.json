{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultilineEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "dart run ${CLAUDE_PLUGIN_ROOT}/scripts/dart-post-edit.dart"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dart run ${CLAUDE_PLUGIN_ROOT}/scripts/dart-stop-fix.dart"
          }
        ]
      }
    ]
  }
}
